# =============================================================================
# 94CramManageSystem — 環境變數範本
# 複製此檔案為 .env 並填入實際值（.env 已在 .gitignore 中，不會被 commit）
# =============================================================================

# ── 共用設定 ──────────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ── 資料庫（PostgreSQL on Google Cloud SQL）──────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/94platform

# ── GCP 設定 ─────────────────────────────────────────────────────────────────
GCP_PROJECT_NUMBER=
GCP_PROJECT_ID=cram94-manage-system
GOOGLE_APPLICATION_CREDENTIALS=

# ── Google OAuth 2.0 ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── manage-backend (port 3100) ───────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
FIREBASE_PROJECT_ID=
TELEGRAM_BOT_TOKEN=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
BOT_API_KEY=
INTERNAL_API_KEY=

# ── inclass-backend (port 3102) ──────────────────────────────────────────────
# DATABASE_URL=（同上共用）
# JWT_SECRET=（同上共用）
IMSTUDY_API_URL=
WEBHOOK_SECRET=
SERVICE_URL=

# ── stock-backend (port 3101) ────────────────────────────────────────────────
# DATABASE_URL=（同上共用）
# JWT_SECRET=（同上共用）

# ── bot-gateway ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_PARENT_BOT_TOKEN=
MANAGE_URL=http://localhost:3100
INCLASS_URL=http://localhost:3102
STOCK_URL=http://localhost:3101
BOT_DASHBOARD_URL=http://localhost:3300
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Dashboard 前端（NEXT_PUBLIC_ 前綴）───────────────────────────────────────
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_MANAGE_URL=http://localhost:3200
NEXT_PUBLIC_INCLASS_URL=http://localhost:3201
NEXT_PUBLIC_STOCK_URL=http://localhost:3000

# ── 通知設定 ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3200,http://localhost:3300
