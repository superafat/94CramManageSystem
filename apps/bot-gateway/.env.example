# Bot Gateway Environment Variables
PORT=3300
NODE_ENV=development

# Telegram Bots
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_PARENT_BOT_TOKEN=your_parent_bot_token_here

# Gemini AI
GEMINI_API_KEY=

# Backend URLs
MANAGE_URL=http://localhost:3100
INCLASS_URL=http://localhost:3102
STOCK_URL=http://localhost:3101
SERVICE_URL=http://localhost:3300
INTERNAL_API_KEY=your_internal_api_key_here

# GCP
GCP_PROJECT_ID=your_gcp_project_id
# Optional: point ADC to a service account key for local smoke tests
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-sa-key.json
